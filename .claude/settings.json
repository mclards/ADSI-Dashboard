{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(python -m unittest discover -s services/tests -p \"test_*.py\")",
      "Bash(find d:/ADSI-Dashboard -name exporter.js -o -name *export* -type f)",
      "Bash(node server/tests/forecastActualAverageTable.test.js)",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\(json.dumps\\(d.get\\(''''scripts'''',{}\\), indent=2\\)\\)\")",
      "Bash(node -e \"const p=require\\(''./package.json''\\); console.log\\(JSON.stringify\\(p.scripts, null, 2\\)\\)\")",
      "Bash(ls node_modules/.bin/electron*)",
      "Bash(node_modules/.bin/electron --version)",
      "Bash(node_modules/.bin/electron server/tests/forecastActualAverageTable.test.js)",
      "Bash(grep -rn \"api_key\\\\|secret\\\\|password\\\\|token\" --include=*.js server/index.js server/exporter.js)",
      "Bash(xargs grep:*)",
      "Bash(ls /d/ADSI-Dashboard/server/*.js)",
      "Bash(grep -n \"rebuildDailyReadingsSummaryForDate\" /d/ADSI-Dashboard/server/*.js)",
      "Bash(grep -iE \"WHERE.*\\\\+|WHERE.*\\\\`\")"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./private/**)"
    ]
  },
  "exclude": [
    ".tmp",
    "test-results",
    "node_modules",
    "release",
    "dist",
    "**/__pycache__",
    "**/*.pyc"
  ]
}
